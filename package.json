{
  "name": "registration-portal",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "build": "turbo run build",
    "dev": "turbo run dev -F @registration-portal/app... -F @registration-portal/api...",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:generate": "turbo run db:generate --filter=@registration-portal/db",
    "db:push": "turbo run db:push --filter=@registration-portal/db",
    "db:studio": "turbo run db:studio --filter=@registration-portal/db"
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "turbo": "^2.4.4",
    "typescript": "^5.6.3"
  },
  "packageManager": "bun@1.3.10",
  "dependencies": {
    "@hugeicons/core-free-icons": "^3.3.0",
    "@hugeicons/react": "^1.1.5"
  }
}
