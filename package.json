{
  "name": "registration-portal",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "build": "turbo run build",
    "dev": "turbo run dev -F @nexus/app... -F @nexus/api...",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:generate": "turbo run db:generate --filter=@nexus/db",
    "db:push": "turbo run db:push --filter=@nexus/db",
    "db:studio": "turbo run db:studio --filter=@nexus/db",
    "seed": "turbo run seed dev --filter=@nexus/db"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint-config-prettier": "^10.1.0",
    "eslint-plugin-prettier": "^5.4.0",
    "eslint-plugin-unused-imports": "^4.1.4",
    "prettier": "^3.4.2",
    "turbo": "^2.4.4",
    "typescript": "^5.6.3"
  },
  "packageManager": "bun@1.3.10",
  "dependencies": {
    "@hugeicons/core-free-icons": "^3.3.0",
    "@hugeicons/react": "^1.1.5"
  }
}
