{
  "name": "@registration-portal/db",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts"
  },
  "scripts": {
    "dev": "trap 'docker compose stop' EXIT; docker compose up --build",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.1",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@registration-portal/eslint": "workspace:*",
    "@registration-portal/tsconfig": "workspace:*",
    "@types/node": "^22.10.1",
    "@types/pg": "^8.11.10",
    "drizzle-kit": "^0.31.8",
    "eslint": "^8.57.0",
    "prettier": "^3.4.2",
    "typescript": "^5.6.3"
  }
}
